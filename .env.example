# Copy to .env and adjust as needed.

# --- Database ---
# Local dev: matches docker-compose.yml db service credentials.
# Render: overridden automatically from the managed Postgres connectionString.
DATABASE_URL=postgresql://

# --- Auth ---
JWT_SECRET=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Seeded admin account ---
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# --- CORS (web origin) ---
CORS_ORIGINS=http://localhost:3000

# --- Shipping ---
SHIPPING_FLAT_INR=99
FREE_SHIPPING_THRESHOLD_INR=2999

# --- Razorpay (leave blank to run checkout in local mock mode) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api
