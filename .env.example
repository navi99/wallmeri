# Copy to .env and adjust as needed. All services read this via docker-compose.

# --- Database ---
# Local dev: matches docker-compose.yml db service credentials.
# Render: overridden automatically from the managed Postgres connectionString.
DATABASE_URL=postgresql://wallmeri:wallmeri@db:5432/wallmeri

# --- Auth ---
JWT_SECRET=dev-secret-change-me-0123456789abcdef
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Seeded admin account (production seed refuses the default password) ---
ADMIN_EMAIL=admin@wallmeri.in
ADMIN_PASSWORD=admin12345
ADMIN_NAME=Wallmeri Admin

# --- CORS (web origin) ---
CORS_ORIGINS=http://localhost:3000

# --- Public base URLs (used for upload URLs and links in emails) ---
PUBLIC_API_BASE_URL=http://localhost:8000
PUBLIC_WEB_BASE_URL=http://localhost:3000

# --- Shipping ---
SHIPPING_FLAT_INR=99
FREE_SHIPPING_THRESHOLD_INR=2999

# --- Razorpay (leave blank to run checkout in local mock mode) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Google sign-in (optional; button hidden when unset) ---
# Create an OAuth 2.0 Web client at https://console.cloud.google.com/apis/credentials
# Authorized JavaScript origins: http://localhost:3000 (+ your prod web URL).
# Set BOTH vars to the same client id (API verifies, web renders the button).
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Object storage for uploaded images (optional; falls back to local disk) ---
# Any S3-compatible store works (Cloudflare R2 recommended). See docs/DEPLOY.md.
S3_BUCKET=
S3_ENDPOINT_URL=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# --- Email (optional; logs to console when SMTP_HOST is unset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=Wallmeri <no-reply@wallmeri.in>

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api
